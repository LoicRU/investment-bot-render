# ============================================================
# Investment Bot — Variables d'environnement
# Colle ces valeurs dans Render → Environment
# ============================================================

# --- Groq API (GRATUIT À VIE) ---
# 1. Va sur https://console.groq.com
# 2. Crée un compte gratuit (pas de CB)
# 3. API Keys → Create API Key → copie la clé
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Telegram Bot ---
# 1. @BotFather sur Telegram → /newbot → copie le token
TELEGRAM_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Envoie un msg à ton bot → ouvre :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    → copie le champ "id" dans "chat"
TELEGRAM_CHAT_ID=123456789

# --- Comportement ---
# weekly = scan chaque lundi (recommandé)
# daily  = scan chaque jour
SCAN_MODE=weekly

# Score minimum pour recevoir une alerte (75=Potentiel / 80=Conviction / 90=Exceptionnel)
ALERT_THRESHOLD=75
