# ============================================================
# Investment Bot - Variables d'environnement (Render)
# À coller dans : Render → ton service → Environment
# ============================================================

# --- Anthropic (Claude API) ---
# https://console.anthropic.com/ → API Keys → Create Key
# Free tier : 5$ offerts au départ, ~2-4 mois en mode weekly
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Telegram Bot ---
# Étape 1 : Parler à @BotFather sur Telegram → /newbot
TELEGRAM_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Étape 2 : Envoyer un msg à ton bot, puis ouvrir :
# https://api.telegram.org/bot<TOKEN>/getUpdates → copier "id"
TELEGRAM_CHAT_ID=123456789

# --- Comportement ---
# weekly = 1 scan/semaine (free tier, ~2-4 mois gratuit)
# daily  = 1 scan/jour  (s'épuise en ~3 semaines)
SCAN_MODE=weekly

# Score minimum pour recevoir une alerte Telegram
# 75=Potentiel | 80=Forte conviction | 90=Exceptionnel
ALERT_THRESHOLD=75

# Modèle Claude utilisé (haiku = 20x moins cher que sonnet)
CLAUDE_MODEL=claude-haiku-4-5-20251001
